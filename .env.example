# Copy to .env in this directory (project root). Used by Docker and by backend + frontend when run locally.

# --- LLM Provider (choose one) ---

# Option 1: Gemini (cloud) — get key at https://aistudio.google.com/apikey
# GEMINI_API_KEY=your_gemini_api_key
# Optional: model name (default gemini-2.5-flash)
# GEMINI_MODEL=gemini-2.5-flash

# Option 2: Local Llama via Ollama (no cloud, no API key needed)
# 1. Install Ollama: https://ollama.com
# 2. Run: ollama pull llama3.1
# 3. Set the vars below and comment out GEMINI_API_KEY
# LLM_PROVIDER=ollama
# OLLAMA_MODEL=BLKWDS/atlas-chat:q4
# OLLAMA_BASE_URL=http://host.docker.internal:11434/v1

# ElevenLabs: TTS + STT https://elevenlabs.io
ELEVENLABS_API_KEY=your_elevenlabs_api_key
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
# Optional: backend URL for frontend when running locally (default http://localhost:4000). Leave empty when using Docker.
# VITE_API_BASE=http://localhost:4000
# Auth: used to sign JWTs (any long random string). Required for register/login and admin employees list.
JWT_SECRET=your_jwt_secret_change_in_production
